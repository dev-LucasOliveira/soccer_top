# Supabase Postgres (required)
# Pooler — use for runtime (Vercel, dev server, seed)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct — required for Prisma migrations (run locally: npm run db:deploy)
# On Vercel builds, use the Session pooler (port 5432), NOT db.[ref].supabase.co,
# unless you enabled Supabase IPv4 add-on.
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"
