generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Player {
  id              String           @id @default(cuid())
  name            String
  primaryPosition String
  nationality     String
  teams           String
  careerStart     Int
  careerEnd       Int
  curatedRankings CuratedRanking[]
  picks           Pick[]
}

model CuratedRanking {
  id       String  @id @default(cuid())
  playerId String
  player   Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  listType String
  position String?
  rank     Int

  @@index([listType, position])
}

model Session {
  id                   String         @id @default(cuid())
  code                 String         @unique
  title                String
  status               String         @default("setup")
  currentRoundNumber   Int            @default(1)
  creatorParticipantId String?
  createdAt            DateTime       @default(now())
  participants         Participant[]
  rounds               Round[]
  result               SessionResult?
}

model Round {
  id          String       @id @default(cuid())
  sessionId   String
  session     Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  number      Int
  title       String
  topN        Int
  filters     String       @default("{}")
  status      String       @default("pending")
  listAliases String?
  createdAt   DateTime     @default(now())
  picks       Pick[]
  votes       Vote[]
  result      RoundResult?
  rankingMeta RankingMeta[]

  @@unique([sessionId, number])
  @@index([sessionId])
}

model Participant {
  id          String    @id @default(cuid())
  sessionId   String
  session     Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  displayName String
  status      String    @default("building")
  userId      String?
  guestToken  String?
  joinedAt    DateTime  @default(now())
  confirmedAt DateTime?
  picks       Pick[]
  rankingMeta RankingMeta[]

  @@unique([sessionId, guestToken])
  @@index([sessionId])
}

model Pick {
  id            String      @id @default(cuid())
  roundId       String
  round         Round       @relation(fields: [roundId], references: [id], onDelete: Cascade)
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  playerId      String
  player        Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  rank          Int

  @@unique([roundId, participantId, rank])
  @@unique([roundId, participantId, playerId])
  @@index([roundId, participantId])
}

model Vote {
  id                  String   @id @default(cuid())
  roundId             String
  round               Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  voterParticipantId  String
  targetParticipantId String
  createdAt           DateTime @default(now())

  @@unique([roundId, voterParticipantId])
  @@index([roundId])
}

model RoundResult {
  id        String   @id @default(cuid())
  roundId   String   @unique
  round     Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  data      String
  createdAt DateTime @default(now())
}

model SessionResult {
  id        String   @id @default(cuid())
  sessionId String   @unique
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  data      String
  createdAt DateTime @default(now())
}

model RankingMeta {
  id            String      @id @default(cuid())
  roundId       String
  round         Round       @relation(fields: [roundId], references: [id], onDelete: Cascade)
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  message       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([roundId, participantId])
  @@index([roundId])
}
