generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Player {
  id              String           @id @default(cuid())
  name            String
  primaryPosition String
  nationality     String
  teams           String
  careerStart     Int
  careerEnd       Int
  curatedRankings CuratedRanking[]
  picks           Pick[]
}

model CuratedRanking {
  id       String  @id @default(cuid())
  playerId String
  player   Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  listType String
  position String?
  rank     Int

  @@index([listType, position])
}

model Session {
  id                     String         @id @default(cuid())
  code                   String         @unique
  title                  String
  status                 String         @default("setup")
  gameMode               String         @default("ranking")
  impostorThemeId        String?
  impostorParticipantId  String?
  currentRoundNumber     Int            @default(1)
  creatorParticipantId   String?
  umSoTotalRounds        Int?
  listaSecretaTotalRounds Int?
  listaSecretaSlotCount   Int?
  pickTimeLimitSeconds   Int?
  createdAt              DateTime       @default(now())
  participants           Participant[]
  rounds                 Round[]
  result                 SessionResult?
}

model Round {
  id          String       @id @default(cuid())
  sessionId   String
  session     Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  number      Int
  title       String
  topN        Int
  filters     String       @default("{}")
  status      String       @default("pending")
  listAliases String?
  cardOptions String?
  createdAt   DateTime     @default(now())
  picks       Pick[]
  votes       Vote[]
  result      RoundResult?
  rankingMeta RankingMeta[]

  @@unique([sessionId, number])
  @@index([sessionId])
}

model AppUser {
  id          String    @id @default(cuid())
  googleId    String    @unique
  email       String    @unique
  displayName String
  username    String    @unique
  usernameSet Boolean   @default(false)
  avatarUrl   String?
  createdAt   DateTime  @default(now())
  lastSeenAt  DateTime?

  participants        Participant[]
  friendshipsSent     Friendship[]    @relation("sent")
  friendshipsReceived Friendship[]    @relation("received")
  matchRecords        MatchRecord[]
  modeStats           UserModeStats[]
}

model Friendship {
  id          String    @id @default(cuid())
  requesterId String
  addresseeId String
  status      String
  createdAt   DateTime  @default(now())
  respondedAt DateTime?

  requester AppUser @relation("sent", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee AppUser @relation("received", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
}

model MatchRecord {
  id        String   @id @default(cuid())
  userId    String
  gameMode  String
  sessionId String?
  score     Int
  placement Int?
  metadata  String   @default("{}")
  playedAt  DateTime @default(now())

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, gameMode, playedAt])
  @@index([gameMode, score(sort: Desc)])
}

model UserModeStats {
  id          String   @id @default(cuid())
  userId      String
  gameMode    String
  gamesPlayed Int      @default(0)
  wins        Int      @default(0)
  totalScore  Int      @default(0)
  bestScore   Int?
  updatedAt   DateTime @updatedAt

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameMode])
}

model Participant {
  id          String    @id @default(cuid())
  sessionId   String
  session     Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  displayName String
  status      String    @default("building")
  userId      String?
  user        AppUser?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestToken  String?
  joinedAt    DateTime  @default(now())
  confirmedAt DateTime?
  picks       Pick[]
  rankingMeta RankingMeta[]

  @@unique([sessionId, guestToken])
  @@index([sessionId])
  @@index([userId])
}

model Pick {
  id            String      @id @default(cuid())
  roundId       String
  round         Round       @relation(fields: [roundId], references: [id], onDelete: Cascade)
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  playerId      String
  player        Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  rank          Int

  @@unique([roundId, participantId, rank])
  @@unique([roundId, participantId, playerId])
  @@index([roundId, participantId])
}

model Vote {
  id                  String   @id @default(cuid())
  roundId             String
  round               Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  voterParticipantId  String
  targetParticipantId String
  createdAt           DateTime @default(now())

  @@unique([roundId, voterParticipantId])
  @@index([roundId])
}

model RoundResult {
  id        String   @id @default(cuid())
  roundId   String   @unique
  round     Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  data      String
  createdAt DateTime @default(now())
}

model SessionResult {
  id        String   @id @default(cuid())
  sessionId String   @unique
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  data      String
  createdAt DateTime @default(now())
}

model RankingMeta {
  id            String      @id @default(cuid())
  roundId       String
  round         Round       @relation(fields: [roundId], references: [id], onDelete: Cascade)
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  message       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([roundId, participantId])
  @@index([roundId])
}
